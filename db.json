Connectivity", "slug": "network", "type": "network", "description": "", "icon": "wifi", "color": "info", "auto_assign_to": null, "is_active": true}}, {"model": "tickets.category", "pk": 3, "fields": {"name": "Software & Applications", "slug": "software", "type": "software", "description": "", "icon": "app-indicator", "color": "success", "auto_assign_to": null, "is_active": true}}, {"model": "tickets.category", "pk": 4, "fields": {"name": "Account & Access", "slug": "account", "type": "account", "description": "", "icon": "person-lock", "color": "warning", "auto_assign_to": null, "is_active": true}}, {"model": "tickets.category", "pk": 5, "fields": {"name": "Security", "slug": "security", "type": "security", "description": "", "icon": "shield-check", "color": "danger", "auto_assign_to": null, "is_active": true}}, {"model": "tickets.category", "pk": 6, "fields": {"name": "Other", "slug": "other", "type": "other", "description": "", "icon": "tag", "color": "secondary", "auto_assign_to": null, "is_active": true}}, {"model": "tickets.ticket", "pk": 1, "fields": {"ticket_id": "TKT-690877", "title": "Account", "description": "I can't be able to login to my Microsoft account", "category": 4, "priority": "critical", "status": "open", "source": "web", "submitted_by": ["user1"], "assigned_to": null, "sla_due_at": "2026-03-11T16:29:07.965Z", "sla_breached": false, "first_response_at": null, "csat_score": null, "csat_comment": "", "created_at": "2026-03-11T08:29:07.965Z", "updated_at": "2026-03-11T08:29:07.965Z", "resolved_at": null, "closed_at": null, "tags": []}}, {"model": "tickets.ticket", "pk": 2, "fields": {"ticket_id": "TKT-063389", "title": "AD", "description": "AD login", "category": 3, "priority": "low", "status": "closed", "source": "web", "submitted_by": ["user1"], "assigned_to": ["agent1"], "sla_due_at": "2026-03-13T08:37:14.384Z", "sla_breached": false, "first_response_at": "2026-03-11T08:55:07.594Z", "csat_score": null, "csat_comment": "", "created_at": "2026-03-11T08:37:14.384Z", "updated_at": "2026-03-11T08:56:38.734Z", "resolved_at": null, "closed_at": "2026-03-11T08:56:38.734Z", "tags": []}}, {"model": "tickets.ticketreply", "pk": 1, "fields": {"ticket": 2, "author": ["admin"], "body": "Your ticket will be handled soon", "is_internal": false, "created_at": "2026-03-11T08:55:07.594Z", "updated_at": "2026-03-11T08:55:07.594Z"}}, {"model": "tickets.ticketreply", "pk": 2, "fields": {"ticket": 2, "author": ["agent1"], "body": "This has been resolved", "is_internal": false, "created_at": "2026-03-11T08:56:28.790Z", "updated_at": "2026-03-11T08:56:28.790Z"}}, {"model": "tickets.cannedresponse", "pk": 1, "fields": {"title": "Acknowledge & Investigating", "body": "Thank you for contacting IT support. I have received your ticket and am currently investigating the issue. I will update you within the hour.", "category": null, "created_by": ["admin"], "created_at": "2026-03-11T08:24:34.158Z", "is_active": true}}, {"model": "tickets.cannedresponse", "pk": 2, "fields": {"title": "Need More Information", "body": "Thank you for your ticket. To help resolve your issue faster, could you please provide:\n\n1. The exact error message (if any)\n2. Which device/computer you are using\n3. What steps lead to the issue\n\nPlease reply with these details and we will proceed.", "category": null, "created_by": ["admin"], "created_at": "2026-03-11T08:24:34.160Z", "is_active": true}}, {"model": "tickets.cannedresponse", "pk": 3, "fields": {"title": "Issue Resolved - Please Confirm", "body": "I believe the issue has been resolved. Could you please test and confirm that everything is working as expected? If you continue to experience problems, please let me know and I will continue investigating.", "category": null, "created_by": ["admin"], "created_at": "2026-03-11T08:24:34.162Z", "is_active": true}}, {"model": "knowledge.kbcategory", "pk": 1, "fields": {"name": "Getting Started", "slug": "getting-started", "description": "New user guides and onboarding", "icon": "rocket", "order": 1}}, {"model": "knowledge.kbcategory", "pk": 2, "fields": {"name": "Hardware", "slug": "kb-hardware", "description": "Device setup and troubleshooting", "icon": "pc-display", "order": 2}}, {"model": "knowledge.kbcategory", "pk": 3, "fields": {"name": "Network", "slug": "kb-network", "description": "VPN, WiFi, and connectivity", "icon": "wifi", "order": 3}}, {"model": "knowledge.kbcategory", "pk": 4, "fields": {"name": "Software", "slug": "kb-software", "description": "Application guides and fixes", "icon": "app-indicator", "order": 4}}, {"model": "knowledge.kbcategory", "pk": 5, "fields": {"name": "Security", "slug": "kb-security", "description": "Password and security policies", "icon": "shield-check", "order": 5}}, {"model": "knowledge.kbcategory", "pk": 6, "fields": {"name": "Account Management", "slug": "kb-account", "description": "Account access and permissions", "icon": "person-gear", "order": 6}}, {"model": "knowledge.article", "pk": 1, "fields": {"title": "How to Submit a Support Ticket", "slug": "how-to-submit-support-ticket", "category": 1, "content": "1. Click \"New Ticket\" in the top navigation or sidebar.\n\n2. Fill in the Ticket Title — be specific about your issue.\n\n3. Select the appropriate Category (Hardware, Software, Network, etc.).\n\n4. Set the Priority level:\n   - Low: Minor inconvenience, no urgency\n   - Medium: Affecting your work but you have a workaround\n   - High: Significantly impacting your work\n   - Critical: Complete outage or security incident\n\n5. Write a detailed Description including:\n   - What you were trying to do\n   - What happened instead\n   - Any error messages you see\n   - When the issue started\n\n6. Attach screenshots or files if they help illustrate the problem.\n\n7. Click Submit Ticket.\n\nYou will receive a confirmation with your ticket ID. You can track the status at any time from the My Tickets page.", "summary": "Step-by-step guide to submitting your first IT support ticket.", "author": ["admin"], "is_published": true, "views": 3, "helpful_yes": 1, "helpful_no": 0, "created_at": "2026-03-11T08:24:34.151Z", "updated_at": "2026-03-11T08:24:34.151Z"}}, {"model": "admin.logentry", "pk": 1, "fields": {"action_time": "2026-03-11T08:51:38.860Z", "user": ["admin"], "content_type": ["accounts", "user"], "object_id": "1", "object_repr": "IT Administrator (IT Manager / Admin)", "action_flag": 2, "change_message": "[{\"changed\": {\"fields\": [\"Email address\", \"Phone\"]}}]"}}, {"model": "admin.logentry", "pk": 2, "fields": {"action_time": "2026-03-11T08:52:16.122Z", "user": ["admin"], "content_type": ["accounts", "user"], "object_id": "2", "object_repr": "Mercy Wambui (IT Support Agent)", "action_flag": 2, "change_message": "[{\"changed\": {\"fields\": [\"First name\", \"Last name\", \"Email address\", \"Phone\"]}}]"}}, {"model": "admin.logentry", "pk": 3, "fields": {"action_time": "2026-03-11T08:52:36.383Z", "user": ["admin"], "content_type": ["accounts", "user"], "object_id": "3", "object_repr": "Joseph mathu (End User)", "action_flag": 2, "change_message": "[{\"changed\": {\"fields\": [\"First name\", \"Last name\", \"Email address\", \"Phone\"]}}]"}}, {"model": "admin.logentry", "pk": 4, "fields": {"action_time": "2026-03-11T09:26:06.713Z", "user": ["admin"], "content_type": ["accounts", "user"], "object_id": "3", "object_repr": "Paul Kama (End User)", "action_flag": 2, "change_message": "[{\"changed\": {\"fields\": [\"First name\", \"Last name\"]}}]"}}, {"model": "admin.logentry", "pk": 5, "fields": {"action_time": "2026-03-11T09:26:48.630Z", "user": ["admin"], "content_type": ["accounts", "user"], "object_id": "1", "object_repr": "IT Administrator (IT Manager / Admin)", "action_flag": 2, "change_message": "[{\"changed\": {\"fields\": [\"password\"]}}]"}}, {"model": "admin.logentry", "pk": 6, "fields": {"action_time": "2026-03-11T09:27:29.346Z", "user": ["admin"], "content_type": ["accounts", "user"], "object_id": "4", "object_repr": "Jos